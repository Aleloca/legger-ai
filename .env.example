DATABASE_URL=postgresql+psycopg://legger:legger@localhost:5432/legger
QDRANT_URL=http://localhost:6333
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
CORPUS_PATH=../italia-corpus

# --- production stack (docker-compose.prod.yml) ---
# Site address WITH scheme: https://legger.ai in prod, http://localhost for
# local smoke runs (Caddy serves plain HTTP when the scheme is http://).
#DOMAIN=https://legger.ai
#POSTGRES_PASSWORD=change-me
# Allowed CORS origins for the API, comma-separated (defaults to DOMAIN).
#CORS_ORIGINS=https://legger.ai
#QDRANT_COLLECTION=norme
#EMBEDDER_NAME=voyage-4-large
# Remap Caddy's published ports (e.g. smoke test next to a dev stack).
#CADDY_HTTP_PORT=80
#CADDY_HTTPS_PORT=443

# --- operational alerting (Telegram, see backend/legger/alerts.py docstring) ---
# Bot token from @BotFather; chat id from /getUpdates after messaging the bot.
# With either unset every alert is a logged no-op — alerting is optional.
#TELEGRAM_BOT_TOKEN=123456:ABC-...
#TELEGRAM_CHAT_ID=

# --- embedding device override (cpu|mps|cuda) ---
# Escape hatch over auto-detection (cuda > mps > cpu); e.g. force cpu when MPS
# wedges in detached indexing runs. See backend/legger/retrieval/embedders.py.
#LEGGER_EMBED_DEVICE=cpu

# --- rate limiting on /chat (per-user IP + cookie; see docs/plans/2026-06-16-rate-limiting-design.md) ---
#RATE_LIMIT_ENABLED=true
#REDIS_URL=redis://redis:6379
#RATE_LIMIT_PER_USER_CONCURRENT=2
#RATE_LIMIT_PER_USER_DAILY=30
#RATE_LIMIT_TZ=Europe/Rome

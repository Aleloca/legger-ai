DATABASE_URL=postgresql+psycopg://legger:legger@localhost:5432/legger
QDRANT_URL=http://localhost:6333
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
CORPUS_PATH=../italia-corpus

# --- production stack (docker-compose.prod.yml) ---
# Site address WITH scheme: https://legger.ai in prod, http://localhost for
# local smoke runs (Caddy serves plain HTTP when the scheme is http://).
#DOMAIN=https://legger.ai
#POSTGRES_PASSWORD=change-me
# Allowed CORS origins for the API, comma-separated (defaults to DOMAIN).
#CORS_ORIGINS=https://legger.ai
#QDRANT_COLLECTION=norme
#EMBEDDER_NAME=voyage-4-large
# Remap Caddy's published ports (e.g. smoke test next to a dev stack).
#CADDY_HTTP_PORT=80
#CADDY_HTTPS_PORT=443
